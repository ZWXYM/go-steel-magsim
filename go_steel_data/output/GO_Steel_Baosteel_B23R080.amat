# Maxwell material library - GO_Steel_Baosteel_B23R080
# Source: Baosteel GO Electrical Steel EVI brochure
# Local source PDF: go_steel_data/pdf/Baosteel_GO_EVI.pdf
# Grade: B23R080
# Family: Domain-refined high permeability GO
# Thickness: 0.23 mm
# Typical table values: P17/50=0.57 W/kg, P17/60=0.77 W/kg, J800=1.91 T, S17/50=1.86 VA/kg
# component1/RD: digitized from Baosteel EVI DC B-H plot
# component2/TD: representative hard-axis estimate, not supplier data
# component3/ND: linear mu_r=1000 placeholder
# H>1000 A/m points are extrapolated toward saturation.
# Core-loss Kh/Kc/Ke are placeholders and left at 0.
# Import in Maxwell: File > Import > Import Material Library

$begin 'GO_Steel_Baosteel_B23R080'
	'CoordinateSystemType'='Cartesian'
	'BulkOrSurface'='Bulk'
	$begin 'PhysicsTypes'
		'set'('Electromagnetic')
	$end 'PhysicsTypes'
	$begin 'AttachedData'
	$end 'AttachedData'
	$begin 'ModifierData'
		$begin 'ThermalModifierData'
			'modifier_data'='no_modifier'
		$end 'ThermalModifierData'
	$end 'ModifierData'
	'permittivity'='1'
	$begin 'permeability'
		'property_type'='AnisoProperty'
		$begin 'component1'
			'property_type'='nonlinear'
			'BTypeForSingleCurve'='Normal'
			'HUnit'='A_per_meter'
			'BUnit'='tesla'
			'IsTemperatureDependent'=false
			$begin 'BHCoordinates'
				'DimUnits'('')
				Points[44: 0, 0, 6, 0.316, 8, 0.481, 10, 0.695, 12, 0.905, 15, 1.153, 20, 1.325, 30, 1.48, 40, 1.56, 50, 1.611, 80, 1.704, 100, 1.739, 150, 1.792, 200, 1.824, 300, 1.862, 500, 1.899, 800, 1.928, 1000, 1.937, 2000, 1.955, 5000, 1.985, 10000, 2.005, 50000, 2.03]
				$begin 'Temperatures'
				$end 'Temperatures'
			$end 'BHCoordinates'
		$end 'component1'
		$begin 'component2'
			'property_type'='nonlinear'
			'BTypeForSingleCurve'='Normal'
			'HUnit'='A_per_meter'
			'BUnit'='tesla'
			'IsTemperatureDependent'=false
			$begin 'BHCoordinates'
				'DimUnits'('')
				Points[42: 0, 0, 30, 0.15, 50, 0.35, 80, 0.6, 100, 0.8, 130, 1, 160, 1.15, 200, 1.28, 250, 1.4, 300, 1.48, 400, 1.56, 500, 1.62, 600, 1.66, 800, 1.7, 1000, 1.74, 1500, 1.78, 2000, 1.82, 3000, 1.86, 5000, 1.9, 10000, 1.94, 50000, 1.97]
				$begin 'Temperatures'
				$end 'Temperatures'
			$end 'BHCoordinates'
		$end 'component2'
		'component3'='1000'
	$end 'permeability'
	'conductivity'='2000000'
	'Tref'='22cel'
	'mass_density'='7650'
	$begin 'core_loss_type'
		'property_type'='ChoiceProperty'
		'Choice'='Electrical Steel'
	$end 'core_loss_type'
	'core_loss_kh'='0'
	'core_loss_kc'='0'
	'core_loss_ke'='0'
	'core_loss_kdc'='0'
	'core_loss_equiv_cut_depth'='0.00023meter'
	'SolveInside'='1'
$end 'GO_Steel_Baosteel_B23R080'
